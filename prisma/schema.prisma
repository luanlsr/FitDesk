// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id              String    @id @default(cuid())
  name            String?
  email           String?   @unique
  emailVerified   DateTime?
  password        String?   // Hashed para Credentials
  role            String    @default("PERSONAL") // MASTER, PERSONAL, STUDENT
  image           String?
  accounts        Account[]
  sessions        Session[]
  leads           Lead[]
  appointments    Appointment[]
  workouts        Workout[]
  exerciseLibrary LibraryExercise[]
  transactions    FinancialEntry[]
  
  // Perfil de Aluno (Vínculo para login de aluno)
  studentProfile  Student?  @relation("StudentProfile")
  
  // FitDesk Fields
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  students        Student[] @relation("PersonalStudents")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? 
  access_token      String? 
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? 
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Student {
  id              String   @id @default(cuid())
  name            String
  cpf             String?
  email           String?
  phone           String?
  birthDate       DateTime?
  gender          String?
  status          String   @default("Ativo")
  goal            String?
  startDate       DateTime @default(now())
  conheceuEm      String?
  
  // Login do Aluno (Link opcional para acesso do próprio aluno)
  associatedUserId String? @unique
  associatedUser   User?   @relation("StudentProfile", fields: [associatedUserId], references: [id])

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relacionamento com o Personal
  userId          String?
  user            User?    @relation("PersonalStudents", fields: [userId], references: [id])

  // Anamnese Detalhada
  lesions         String?
  conditions      String?
  medications     String?
  restricoes      String?
  cirurgias       String?
  hipertensao     Boolean  @default(false)
  diabetes        Boolean  @default(false)
  fumante         Boolean  @default(false)
  observacoes     String?

  // Conformidade LGPD & Segurança
  acceptedTerms   Boolean   @default(false)
  acceptedTermsAt DateTime?
  deletedAt       DateTime? // Soft delete para conformidade

  paymentDay      Int?      // Dia do vencimento
  planValue       Float?    // Valor da mensalidade combinada
  
  appointments    Appointment[]
  assessments     Assessment[]
  workouts        Workout[]
  transactions    FinancialEntry[]
}

model FinancialEntry {
  id              String   @id @default(cuid())
  description     String
  amount          Float
  type            String   // IN (Receita), OUT (Despesa)
  category        String   // Mensalidade, Equipamento, Aluguel, Marketing, etc.
  date            DateTime @default(now())
  
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  studentId       String?
  student         Student? @relation(fields: [studentId], references: [id], onDelete: SetNull)

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Assessment {
  id              String   @id @default(cuid())
  date            DateTime @default(now())
  weight          Float?
  height          Float?
  imc             Float?
  bodyFat         Float?
  muscleMass      Float?
  
  // Circunferências
  waist           Float?
  hip             Float?
  chest           Float?
  
  studentId       String
  student         Student  @relation(fields: [studentId], references: [id])
}

model Workout {
  id              String   @id @default(cuid())
  name            String   // Treino A, B, etc.
  description     String?
  
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  studentId       String
  student         Student  @relation(fields: [studentId], references: [id])
  exercises       Exercise[]
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Exercise {
  id              String   @id @default(cuid())
  name            String
  sets            Int
  reps            String
  weight          String?
  rest            String?
  workoutId       String
  workout         Workout  @relation(fields: [workoutId], references: [id], onDelete: Cascade)
}

model LibraryExercise {
  id              String   @id @default(cuid())
  name            String
  category        String   // Ex: Peito, Costas, Pernas...
  videoUrl        String?
  
  userId          String?  // Opcional: exercícios globais ou personalizados do personal
  user            User?    @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Appointment {
  id              String   @id @default(cuid())
  title           String   // Ex: Treino de Pernas, Avaliação
  description     String?
  start           DateTime
  end             DateTime
  status          String   @default("Agendado") // Agendado, Concluído, Cancelado, Falta
  
  userId          String   // Personal Trainer
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  studentId       String?  // Opcional caso seja bloqueio de agenda
  student         Student? @relation(fields: [studentId], references: [id], onDelete: SetNull)

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Lead {
  id              String   @id @default(cuid())
  name            String
  email           String?
  phone           String?
  status          String   @default("Novo") // Novo, Em Contato, Experimental, Convertido, Perdido
  origin          String?  // Instagram, Indicação, Site, etc.
  value           Float?   // Valor estimado do plano
  notes           String?
  
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}
